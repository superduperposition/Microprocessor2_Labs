void updateBuzzer(float dist) {
  if (dist >= 60.0f) {
    noTone(BUZZER_PIN);
  } else if (dist >= 20.0f) {
    int freq_hz = map((long)dist, 20L, 60L, 2000L, 500L);
    tone(BUZZER_PIN, freq_hz);
  } else {
    tone(BUZZER_PIN, 2000);
  }
}
