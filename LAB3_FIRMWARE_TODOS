float measureDistance() {
  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);

  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);
  digitalWrite(TRIG_PIN, LOW);

  unsigned long pulse_duration = pulseIn(ECHO_PIN, HIGH, 30000UL);

  if (pulse_duration == 0) {
    return 0.0f;
  }

  float distance_cm = pulse_duration * 0.034f / 2.0f;
  return distance_cm;
}

