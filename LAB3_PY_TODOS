def decode_frame(data: bytes) -> Optional[ParkingFrame]:
    if len(data) != FRAME_LEN:
        return None

    if data[0] != FRAME_START:
        return None

    computed_checksum = 0
    for byte in data[1:6]:
        computed_checksum ^= byte

    if computed_checksum != data[6]:
        return None

    distance_tenths = (data[1] << 8) | data[2]
    distance_cm = distance_tenths / 10.0

    return ParkingFrame(
        distance_cm=distance_cm,
        motor_pwm=data[3],
        alarm_state=data[4],
        zone_id=data[5],
        timestamp=time.time(),
    )

