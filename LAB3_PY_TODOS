def encode_frame(
    distance_cm: float,
    motor_pwm: int,
    alarm_state: int,
    zone_id: int,
) -> bytes:
    distance_tenths = int(round(distance_cm * 10.0))

    if distance_tenths < 0:
        distance_tenths = 0
    elif distance_tenths > 65535:
        distance_tenths = 65535

    dist_hi = (distance_tenths >> 8) & 0xFF
    dist_lo = distance_tenths & 0xFF

    checksum = dist_hi ^ dist_lo ^ motor_pwm ^ alarm_state ^ zone_id

    return bytes([
        FRAME_START,
        dist_hi,
        dist_lo,
        motor_pwm & 0xFF,
        alarm_state & 0xFF,
        zone_id & 0xFF,
        checksum & 0xFF,
    ])

